{
  "bg_color": "#1a1a2e",
  "layout": {
    "display": {
      "width": 1920,
      "height": 515
    }
  },
  "widgets": [
    {
      "id": "pomodoro",
      "type": "pomodoro",
      "x": 0,
      "y": 0,
      "width": 640,
      "height": 515,
      "settings": {
        "work_minutes": 25,
        "short_break_minutes": 5,
        "long_break_minutes": 15,
        "cycles_before_long_break": 4,
        "font": "Inter",
        "work_accent_color": "#00ff00",
        "short_break_accent_color": "#44ff44",
        "long_break_accent_color": "#4488ff"
      }
    },
    {
      "id": "calendar",
      "type": "calendar",
      "x": 640,
      "y": 0,
      "width": 640,
      "height": 515,
      "settings": {
        "clock_format": "12h",
        "font": "Inter",
        "time_color": "#ffffff",
        "date_color": "#dcdcdc"
      }
    },
    {
      "id": "notification",
      "type": "notification",
      "x": 1280,
      "y": 0,
      "width": 640,
      "height": 515,
      "settings": {
        "font": "Inter",
        "auto_dismiss_seconds": 30,
        "blocked_apps": []
      }
    }
  ],
  "shortcuts": {
    "pomodoro_start": "Ctrl+S",
    "pomodoro_pause": "Ctrl+P",
    "pomodoro_reset": "Ctrl+R"
  }
}
